# ============================================================================
#  EVERYTHING .gitignore – The Ultimate Set
#  --------------------------------------------------------------------------
#  Use this as your default .gitignore. Remove sections you don't need.
#  Lines starting with '#' are comments – keep them for documentation.
# ============================================================================

# ----------------------------------------------------------------------------
#  OS / System files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
*.cache
*.log
*.pid
*.seed
*.pid.lock
*.sock

# ----------------------------------------------------------------------------
#  Archives & compressed files (usually not needed in repo)
# ----------------------------------------------------------------------------
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip
*.pkg
*.apk
*.msi
*.exe
*.dll
*.so
*.dylib

